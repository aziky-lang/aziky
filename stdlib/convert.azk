pub fn checked_f32(text: string) -> Result<f32, ParseError> {
    let parsed: Result<f32, string> = text.parse_f32();
    if parsed.is_ok() { return Result::Ok(parsed.unwrap_or(0.0f32)); }
    let error: ParseError = ParseError::InvalidInput;
    return Result::Err(error);
}

pub fn checked_f64(text: string) -> Result<f64, ParseError> {
    let parsed: Result<f64, string> = text.parse_f64();
    if parsed.is_ok() { return Result::Ok(parsed.unwrap_or(0.0f64)); }
    let error: ParseError = ParseError::InvalidInput;
    return Result::Err(error);
}

pub fn checked_bool(text: string) -> Result<bool, ParseError> {
    let parsed: Result<bool, string> = text.parse_bool();
    if parsed.is_ok() { return Result::Ok(parsed.unwrap_or(false)); }
    let error: ParseError = ParseError::InvalidInput;
    return Result::Err(error);
}
