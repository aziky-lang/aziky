pub fn checked_char_at(text: string, index: u64) -> Option<char> {
    return text.char_at(index);
}

pub fn checked_char(value: u32) -> Option<char> {
    return value.to_char_checked();
}

pub enum ParseError {
    InvalidInput,
}

pub fn checked_i8(text: string) -> Result<i8, ParseError> {
    let parsed: Result<i8, string> = text.parse_i8();
    if parsed.is_ok() { return Result::Ok(parsed.unwrap_or(0i8)); }
    let error: ParseError = ParseError::InvalidInput;
    return Result::Err(error);
}

pub fn checked_i16(text: string) -> Result<i16, ParseError> {
    let parsed: Result<i16, string> = text.parse_i16();
    if parsed.is_ok() { return Result::Ok(parsed.unwrap_or(0i16)); }
    let error: ParseError = ParseError::InvalidInput;
    return Result::Err(error);
}

pub fn checked_i32(text: string) -> Result<i32, ParseError> {
    let parsed: Result<i32, string> = text.parse_i32();
    if parsed.is_ok() { return Result::Ok(parsed.unwrap_or(0i32)); }
    let error: ParseError = ParseError::InvalidInput;
    return Result::Err(error);
}

