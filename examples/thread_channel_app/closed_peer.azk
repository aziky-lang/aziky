fn send_closed(sender: Sender<u64>) -> u64 {
    sender.send(1u64);
    return 0u64;
}

fn main() {
    let channel: Channel<u64> = Channel::bounded(1u64);
    let sender: Sender<u64> = channel.sender();
    let receiver: Receiver<u64> = channel.receiver();
    receiver.close();
    let thread: Thread = Thread::spawn(send_closed, sender);
    let status: u64 = thread.join();
    exit(status);
}
