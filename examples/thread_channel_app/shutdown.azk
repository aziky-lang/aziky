fn fill(sender: Sender<u64>) -> u64 {
    sender.send(1u64);
    sender.send(2u64);
    sender.close();
    return 0u64;
}

fn main() {
    let channel: Channel<u64> = Channel::bounded(1u64);
    let sender: Sender<u64> = channel.sender();
    let receiver: Receiver<u64> = channel.receiver();
    let worker: Thread = Thread::spawn(fill, sender);
    exit(0u64);
}
